{
  "name": "opencode-memoir",
  "version": "1.1.5",
  "description": "Memoir memory plugin for OpenCode — Git-versioned, taxonomy-structured AI memory.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json --declaration --emitDeclarationOnly && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:node:* --external:@opencode-ai/plugin --sourcemap",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "prepublishOnly": "npm run build && npm test && node -e \"import('./dist/index.js').then(m=>{const d=m.default;if(!d||typeof d!=='object'||typeof d.server!=='function'||d.id!=='opencode-memoir'){console.error('Smoke FAILED: default export is not a V1 plugin module ({ id, server })');process.exit(1)}else{console.log('Smoke OK: id=',d.id,'server=',typeof d.server)}})\""
  },
  "keywords": [
    "opencode",
    "memoir",
    "memory",
    "version-control",
    "taxonomy",
    "plugin"
  ],
  "author": "Dmitrii Safronov <dhameoelin@gmail.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/disafronov/opencode-memoir",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/disafronov/opencode-memoir.git"
  },
  "bugs": {
    "url": "https://github.com/disafronov/opencode-memoir/issues"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "allowScripts": {
    "esbuild@0.28.0": true
  }
}
